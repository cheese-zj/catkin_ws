Panels: []
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz/Image
      Enabled: true
      Image Topic: /realsense_left/color/image_raw
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Wrist_Left
      Normalize Range: true
      Queue Size: 2
      Transport Hint: compressed
      Unreliable: false
      Value: true
    - Class: rviz/Image
      Enabled: true
      Image Topic: /realsense_right/color/image_raw
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Wrist_Right
      Normalize Range: true
      Queue Size: 2
      Transport Hint: compressed
      Unreliable: false
      Value: true
    - Class: rviz/Image
